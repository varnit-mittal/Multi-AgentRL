# =============================================================================
# Whispers — inference.py environment variables
# =============================================================================
# Copy this file to `.env` and fill in real values.
# `.env` is gitignored, so secrets never get committed.
#
#   cp .env.example .env
#   # then edit .env
#   python inference.py
# =============================================================================

# ---- REQUIRED -------------------------------------------------------------

# HuggingFace access token (https://huggingface.co/settings/tokens).
# Used as the API key for the OpenAI-compatible client.
# `API_KEY` is also accepted if you prefer to keep an alias.
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Any OpenAI-API-compatible base URL. Examples:
#   https://router.huggingface.co/v1            (HF Inference Providers router)
#   https://api.openai.com/v1                    (OpenAI directly)
#   https://api.together.xyz/v1                  (Together)
#   https://openrouter.ai/api/v1                 (OpenRouter)
API_BASE_URL=https://router.huggingface.co/v1

# Chat-completions model name as recognised by the provider above.
# Examples:
#   Qwen/Qwen2.5-7B-Instruct                     (HF router)
#   meta-llama/Meta-Llama-3.1-8B-Instruct        (HF router)
#   gpt-4o-mini                                  (OpenAI)
MODEL_NAME=Qwen/Qwen2.5-7B-Instruct


# ---- OPTIONAL -------------------------------------------------------------

# Run against a remote Whispers HTTP server instead of the in-process env.
# Leave unset to use the in-process WhispersEnv (faster, no network).
# Examples:
#   http://localhost:7860                        (local docker)
#   https://varn03-whispers.hf.space             (your HF Space)
# WHISPERS_URL=http://localhost:7860

# Run a single task instead of looping over all six (t1..t6).
# WHISPERS_TASK=t3

# Episode RNG seed (default: 0). Same seed -> same hidden ground-truth event.
# WHISPERS_SEED=0

# Hard cap on steps per episode (default: task's own max_steps).
# MAX_STEPS=20

# Override the .env path explicitly (default: ./.env or <repo>/.env).
# DOTENV_PATH=/abs/path/to/some.env
